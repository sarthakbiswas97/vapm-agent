DECISION_PROGRAM_ID=6xDo2r8Edvu1MHxwUtqmmzm3Auavf2fokbjGoJHxcMLx
BLOCKCHAIN_ENABLED=false

# Jupiter
JUPITER_API_URL=https://api.jup.ag

# Token Mints (Solana)
SOL_MINT=So11111111111111111111111111111111111111112
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Ika dWallet (MPC custody with decentralized guardrails)
IKA_GRPC_URL=pre-alpha-dev-1.ika.ika-network.net:443
IKA_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY
